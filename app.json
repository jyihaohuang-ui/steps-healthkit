{
  "expo": {
    "name": "步數工具",
    "slug": "steps-healthkit",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gpstool.stepshealthkit",
      "infoPlist": {
        "NSHealthShareUsageDescription": "需要讀取您的步數與健康資料",
        "NSHealthUpdateUsageDescription": "需要將步數寫入 Apple Health",
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.access": []
      }
    },
    "plugins": [
      [
        "react-native-health",
        {
          "isClinicalDataEnabled": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "a83b5264-dd8e-4db6-b0ca-6a2907e3b28b"
      }
    }
  }
}
